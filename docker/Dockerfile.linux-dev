FROM mcr.microsoft.com/devcontainers/javascript-node:20

# Install system deps for Electron builds and Chromium runtime
# Package names are for Debian Trixie (13) — some were renamed from Bookworm.
RUN apt-get update && apt-get install -y \
    # Build tools
    python3 \
    make \
    g++ \
    # Electron build deps (native module compilation)
    libx11-dev \
    libxkbfile-dev \
    libsecret-1-dev \
    # Electron/Chromium runtime deps (Trixie-specific names)
    libgtk-3-0 \
    libgdk-pixbuf-2.0-0 \
    libnss3 \
    libnspr4 \
    libatk1.0-0t64 \
    libatk-bridge2.0-0t64 \
    libcups2t64 \
    libxss1 \
    libxcomposite1 \
    libxrandr2 \
    libxdamage1 \
    libxfixes3 \
    libxext6 \
    libx11-xcb1 \
    libxcb1 \
    libxcb-dri3-0 \
    libxkbcommon0 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2t64 \
    libgbm1 \
    libdrm2 \
    libexpat1 \
    libdbus-1-3 \
    libxi6 \
    libxtst6 \
    libxrender1 \
    libxcursor1 \
    # D-Bus session (Electron uses it for notifications / tray)
    dbus \
    dbus-x11 \
    # Packaging tools
    rpm \
    fakeroot \
    dpkg-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Bun 1.3.11 via npm (no curl/download script needed)
RUN npm install -g bun@1.3.11

WORKDIR /workspace

CMD ["bash"]
