{
	"name": "@superset/cli-wrapper",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e ../../.env -o -- sh -c 'exec env SUPERSET_API_URL=$NEXT_PUBLIC_API_URL cli-framework dev \"$@\"' --",
		"build": "cli-framework build",
		"build:linux-x64": "cli-framework build --target=bun-linux-x64 --outfile=./dist/superset-cli",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "1.19.13",
		"@superset/cli": "workspace:*",
		"@superset/cli-framework": "workspace:*",
		"@superset/db": "workspace:*",
		"@superset/shared": "workspace:*",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.25",
		"jsonwebtoken": "^9.0.2",
		"postgres": "^3.4.4",
		"uuid": "14.0.0"
	},
	"devDependencies": {
		"@superset/typescript": "workspace:*",
		"@types/jsonwebtoken": "^9.0.5",
		"@types/uuid": "11.0.0",
		"bun-types": "1.3.11",
		"typescript": "6.0.3"
	}
}
